<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Anfitrionas en Huanuco</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
}

/* HEADER */
header {
  background: black;
  color: white;
  padding: 15px 50px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

nav a {
  color: white;
  margin: 0 10px;
  text-decoration: none;
}

.btn-contacto {
  background: #ff0f4f;
  padding: 10px 20px;
  border-radius: 20px;
}

/* HERO CON FONDO */
.hero {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 50px;
  
  /* 👇 TU LOGO COMO FONDO */
  background: url("c:\\Users\\ASUS\\Desktop\\WhatsApp Image 2026-03-31 at 6.13.49 PM.jpeg") no-repeat center;
  background-size: cover;
}

/* OSCURECER FONDO (para que se vea elegante) */
.hero::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
}

/* CONTENIDO ENCIMA */
.hero-content {
  position: relative;
  display: flex;
  width: 100%;
  justify-content: space-between;
}

/* IMAGEN MODELOS */
.hero img {
  width: 40%;
  border-radius: 10px;
}

/* FORM */
.form-box {
  width: 40%;
  background: white;
  padding: 20px;
  border-radius: 10px;
}

.form-box h2 {
  background: #ff0f4f;
  color: white;
  padding: 10px;
  border-radius: 10px;
  text-align: center;
}

.form-box input,
.form-box textarea {
  width: 100%;
  padding: 10px;
  margin: 10px 0;
  border: 2px solid #ff0f4f;
  border-radius: 8px;
}

.form-box button {
  width: 100%;
  padding: 12px;
  background: #ff0f4f;
  color: white;
  border: none;
  border-radius: 20px;
  cursor: pointer;
}

/* SECTION */
.section {
  background: #ff0f4f;
  color: white;
  text-align: center;
  padding: 40px;
}
</style>

</head>

<body>

<header>
  <h2>ANFITRIONAS DE HUANUCO</h2>
  <nav>
    <a href="#">Inicio</a>
    <a href="#">Eventos</a>
    <a href="#">Servicios</a>
    <a href="#">Blog</a>
    <a class="btn-contacto" href="#">Contacto</a>
  </nav>
</header>

<section class="hero">

  <div class="hero-content">

    <!-- IMAGEN DELANTE -->
    <img src="c:\Users\ASUS\Desktop\76b82236-a2aa-4a95-a463-afa3aa57f535.jpg" alt="modelos">

    <!-- FORMULARIO -->
    <div class="form-box">
      <h2>ANFITRIONAS Y MODELOS DE HUANUCO</h2>

      <input type="text" placeholder="Nombres y Apellidos (EMPRESA)">
      <input type="text" placeholder="Teléfono">
      <input type="email" placeholder="Email">

      <textarea rows="4" placeholder="Cuéntanos sobre tu evento..."></textarea>

      <button>COTIZAR</button>
    </div>

  </div>

</section>

<section class="section">
  <h2>NUESTRA AGENCIA DE ANFITRIONAS EN HUANUCO</h2>
  <p>
    Somos líderes en organización y gestión de eventos en Huanuco, Perú.
    Contamos con anfitrionas altamente capacitadas para todo tipo de eventos.
  </p>
</section>

</body>
</html>
